# Rename this file to .env and fill in your own values

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce_mern

# JWT secret key - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
